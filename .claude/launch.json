{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "goal-coach-server",
      "runtimeExecutable": "node",
      "runtimeArgs": ["server/src/index.js"],
      "port": 3001,
      "env": {
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}",
        "DB_PATH": "./data/goals.db",
        "PORT": "3001"
      }
    },
    {
      "name": "goal-coach-client",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "client"],
      "port": 5173
    }
  ]
}
